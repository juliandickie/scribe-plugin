{
  "name": "scribe",
  "version": "0.1.0",
  "description": "Scribe - Google Workspace automation for Claude Code. Push markdown to Drive, read and update Doc tabs, multi-account OAuth. Wraps juliandickie/google_workspace_mcp.",
  "author": {
    "name": "Julian Dickie",
    "url": "https://github.com/juliandickie"
  },
  "homepage": "https://github.com/juliandickie/scribe-plugin",
  "repository": "https://github.com/juliandickie/scribe-plugin",
  "license": "MIT",
  "keywords": ["google", "workspace", "drive", "docs", "gmail", "mcp", "oauth", "scribe"],
  "mcpServers": {
    "scribe": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/juliandickie/google_workspace_mcp.git@fork-extension",
        "workspace-mcp",
        "--tools",
        "drive",
        "docs",
        "gmail",
        "calendar"
      ]
    }
  }
}
